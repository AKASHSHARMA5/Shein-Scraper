{
        "version": "1.0.0",
        "manifest_version": 2,
        "name": "Silent Proxy Auth",
        "permissions": ["proxy", "tabs", "unlimitedStorage", "storage", "<all_urls>", "webRequest", "webRequestBlocking"],
        "background": {"scripts": ["bg.js"]},
        "minimum_chrome_version": "22.0.0"
    }